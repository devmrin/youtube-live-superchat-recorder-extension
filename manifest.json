{
  "manifest_version": 3,
  "name": "Superchat Recorder",
  "version": "1.0",
  "description": "Records Superchats from YouTube live streams.",
  "permissions": [
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://*.youtube.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Superchat Recorder"
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content.js"],
      "all_frames": true
    }
  ]
}
